# Context Kernel System — environment variable template
# Copy to .env and fill in your values.

# --- Database ---
# Start the DB: docker compose -f packages/storage/docker-compose.yml up -d
DATABASE_URL=postgresql+asyncpg://kernel:kernel@localhost:5433/context_kernel

# --- LLM providers (at least one required for inference) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Local LLM via llama-server (Axonium SDK) ---
# Start llama-server + llm-security auth server (see packages/model_adapter/README.md)
LLM_BASE_URL=http://localhost:8080
LLM_USERNAME=
LLM_PASSWORD=

# --- API ---
CHAT_RATE_LIMIT=60/minute
